<Page x:Class="HZtest.View.RelativeCoordinateSystemPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:HZtest.Resources_资源.Control"
      xmlns:vm="clr-namespace:HZtest.ViewModels"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="RelativeCoordinateSystemPage">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="3*"/>

        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Row="0" Grid.Column="0"  Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" >
            <TextBlock Text="坐标系:" FontSize="24" FontWeight="Bold" Margin="50,10,0,10" VerticalAlignment="Center"/>
            <ComboBox 
                    ItemsSource="{Binding CoordinateSystemOptions}"
                    DisplayMemberPath="Description"
                    SelectedValuePath="Value"
                    SelectedValue="{Binding SelectedCoordinateSystem}"
                    FontSize="20"
                    Width="250"
                    Height="30"
                    Margin="10"/>
        </StackPanel>

        <StackPanel Grid.Row="0" Grid.Column="1"  Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" >
            <Button  Content="查询" FontSize="24"  Height="35" Width="100" Margin="20,0,0,0" VerticalAlignment="Center" Command="{Binding CoordinateSystemQueryCommand}"/>
            <Button  Content="上传" FontSize="24"  Height="35" Width="100" Margin="30,0,0,0" VerticalAlignment="Center" Command="{Binding CoordinateSystemUploadCommand}"/>
        </StackPanel>






        <Grid  Grid.Row="1" Grid.ColumnSpan="2">
            <local:RelativeCoordinateSystemControl 
            HorizontalAlignment="Stretch" 
            VerticalAlignment="Stretch"
            DataContext="{Binding CoordinateSystemData}"  />
        </Grid>


    </Grid>
</Page>
