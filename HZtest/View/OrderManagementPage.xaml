        <!-- 第一行：查询区域 -->
        <Grid Grid.Row="0" Margin="3,10,0,10"  Grid.ColumnSpan="2"   >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="230"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 报警代码标签 -->
            <TextBlock Grid.Column="0"  Text="订单编号：" VerticalAlignment="Center" FontSize="20"/>

            <!-- 输入框 -->
            <TextBox Grid.Column="1" 
                 Text="{Binding SearchOrderCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Height="30" 
                 FontSize="20"
                 VerticalContentAlignment="Center"
                 Margin="5,0"/>

            <!-- 查询按钮 -->
            <Button Grid.Column="2" 
                Content="查询" 
                Command="{Binding SearchCommand}"
                Width="60" 
                Height="30"
                Margin="10,0"
                Cursor="Hand"/>
            <!-- 新增按钮（靠右） -->
            <Button Grid.Column="3" 
            Grid.Row="0"
                Content="+ 新增订单" 
                Command="{Binding AddCommand}"
                Width="120" 
                Height="30"
                Background="#2196F3"
                Foreground="White"
                Cursor="Hand"/>
        </Grid>


        <!-- 第二行：数据列表 -->
        <Border Grid.Row="2"
            Grid.ColumnSpan="2"
            BorderBrush="#DDDDDD" 
            BorderThickness="1" 
            CornerRadius="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 表头 -->
                    <Grid Background="#F5F5F5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="订单编号" FontWeight="Bold" Padding="10,8" TextAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="订单数量" FontWeight="Bold" Padding="10,8" TextAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="加工件名称" FontWeight="Bold" Padding="10,8" TextAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="加工文件" FontWeight="Bold" Padding="10,8" TextAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="状态" FontWeight="Bold" Padding="10,8" TextAlignment="Center"/>
                        <TextBlock Grid.Column="5" Text="创建时间" FontWeight="Bold" Padding="10,8" TextAlignment="Center"/>
                        <TextBlock Grid.Column="6" Text="操作" FontWeight="Bold" Padding="10,8" TextAlignment="Center"/>
                    </Grid>

                    <!-- 数据行 -->
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding OrderManagementList}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#EEEEEE" 
                                    BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- 订单编号 -->
                                        <TextBlock Grid.Column="0" 
                                               Text="{Binding OrderCode}" 
                                               Padding="10,12" 
                                               TextAlignment="Center"
                                               VerticalAlignment="Center"/>

                                        <!-- 订单数量 -->
                                        <TextBlock Grid.Column="1" 
                                               Text="{Binding OrderQuatity}" 
                                               Padding="10,12" 
                                               TextAlignment="Center"
                                               VerticalAlignment="Center">
                                        </TextBlock>

                                        <!-- 加工件名称 -->
                                        <TextBlock Grid.Column="2" 
                                               Text="{Binding ProcessingPartName}" 
                                               Padding="10,12" 
                                               TextAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="Gray"
                                               FontSize="12"/>
                                        <!-- 加工文件 -->
                                        <TextBlock Grid.Column="3" 
                                                   Text="{Binding ProcessingPartFilePath}" 
                                                   Padding="10,12" 
                                                   TextAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="Gray"
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis"
                                                   >
                                            <TextBlock.ToolTip>
                                                <ToolTip Content="{Binding ProcessingPartFilePath}" MaxWidth="400"/>
                                            </TextBlock.ToolTip>
                                        </TextBlock>
                                        <!-- 状态 -->
                                        <TextBlock Grid.Column="4" 
                                                   Text="{Binding OrderState}" 
                                                   Padding="10,12" 
                                                   TextAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="Gray"
                                                   FontSize="12"/>
                                        <!-- 创建时间 -->
                                        <TextBlock Grid.Column="5" 
                                                   Text="{Binding CreateTime, StringFormat= 'yyyy-MM-dd HH:mm:ss'}"
                                                   Padding="10,12" 
                                                   TextAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Foreground="Gray"
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis"
                                                   >
                                            <TextBlock.ToolTip>
                                                <ToolTip Content="{Binding CreateTime}" MaxWidth="400"/>
                                            </TextBlock.ToolTip>
                                        </TextBlock>

                                        <!-- 操作按钮 -->
                                        <StackPanel Grid.Column="6" 
                                                Orientation="Horizontal" 
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                            <Button Content="修改" 
                                                Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Width="50" 
                                                Height="26"
                                                Margin="5,0"
                                                Background="#4CAF50"
                                                Foreground="White"
                                                Cursor="Hand"/>

                                            <Button Content="删除" 
                                                Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"
                                                Width="50" 
                                                Height="26"
                                                Margin="5,0"
                                                Background="#F44336"
                                                Foreground="White"
                                                Cursor="Hand"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
