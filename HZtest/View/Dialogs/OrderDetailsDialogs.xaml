<UserControl x:Class="HZtest.View.Dialogs.OrderDetailsDialogs"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HZtest.View.Dialogs"
             xmlns:Converters="clr-namespace:HZtest.Converters_值转换"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <!-- 定义转换器 -->
        <Converters:EnumToDescriptionConverter x:Key="EnumDescConverter"/>
    </UserControl.Resources>
    <Border Background="White" BorderBrush="Gray" BorderThickness="2" CornerRadius="5" Padding="20" Width="700" Height="500">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- 关闭按钮（右上角） -->
            <Button Grid.Row="0" 
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,-10,-10,0"
                    Content="✕"
                    Command="{Binding CloseCommand}"
                    Width="32" 
                    Height="32"
                    FontSize="16"
                    FontWeight="Bold"
                    Background="Transparent"
                    Foreground="#666666"
                    BorderThickness="0"
                    Cursor="Hand"
                    ToolTip="关闭">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF4444"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <!-- 第一行：查询区域 -->
            <Grid Grid.Row="0" Margin="0,10,0,10"  Grid.ColumnSpan="2"   >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="190"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 标签 -->
                <TextBlock Grid.Column="0" Text="订单：" VerticalAlignment="Center" FontSize="17"/>

                <!-- 订单选择框 -->
                <ComboBox  
                         Grid.Row="0"
                         Grid.Column="1"
                         Margin="10,0,0,0"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Left"
                         ItemsSource="{Binding OrderList}"
                         DisplayMemberPath="Description"
                         SelectedValuePath="Value"
                         SelectedValue="{Binding SelectedOrderID}"
                         FontSize="17"
                         Width="180"
                         Height="25"
                         />
                <!-- 标签 -->
                <TextBlock  Margin="10,0,0,0" Grid.Column="2" Text="状态：" VerticalAlignment="Center" FontSize="17"/>
                <!-- 状态选择框 -->
                <ComboBox  
                         Grid.Row="0"
                         Grid.Column="3"
                         Margin="10,0,0,0"
                         VerticalAlignment="Center"
                         HorizontalAlignment="Left"
                         ItemsSource="{Binding OrderDetailsTypeList}"
                         DisplayMemberPath="Description"
                         SelectedValuePath="Value"
                         SelectedValue="{Binding SelectedOrderDetailsType}"
                         FontSize="17"
                         Width="180"
                         Height="25"
                         />

                <!-- 查询按钮 -->
                <Button Grid.Column="4" 
                        Content="查询" 
                        Command="{Binding SearchCommand}"
                        Width="60" 
                        Height="30"
                        Margin="10,0"
                        Cursor="Hand"/>
            </Grid>


            <!-- 第二行：数据列表 -->
            <Border Grid.Row="2"
                    Grid.ColumnSpan="2"
                    BorderBrush="#DDDDDD" 
                    BorderThickness="1" 
                    CornerRadius="4">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 表头 -->
                        <Grid Background="#F5F5F5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="订单编号" FontWeight="Bold" Padding="10,8" TextAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="开始时间" FontWeight="Bold" Padding="10,8" TextAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="完工时间" FontWeight="Bold" Padding="10,8" TextAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="需求数量" FontWeight="Bold" Padding="10,8" TextAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="状态" FontWeight="Bold" Padding="10,8" TextAlignment="Center"/>
                        </Grid>

                        <!-- 数据行 -->
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding OrderDetailsList}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#EEEEEE" 
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="120"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!--订单编号 -->
                                            <TextBlock Grid.Column="0" 
                                                       Text="{Binding OrderCode}" 
                                                       Padding="10,12" 
                                                       TextAlignment="Center"
                                                       VerticalAlignment="Center"/>

                                            <!-- 开始时间 -->
                                            <TextBlock Grid.Column="1" 
                                                       Text="{Binding StartTime, StringFormat='yyyy-MM-dd HH:mm:ss'}" 
                                                       Padding="10,12" 
                                                       TextAlignment="Center"
                                                       VerticalAlignment="Center">
                                                <!--<TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding AlarmLevel}" Value="ErrorLevel">
                                                                <Setter Property="Foreground" Value="#F44336"/>
                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding AlarmLevel}" Value="MessageLevel">
                                                                <Setter Property="Foreground" Value="#FF9800"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding AlarmLevel}" Value="LOW">
                                                                <Setter Property="Foreground" Value="#4CAF50"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>-->
                                            </TextBlock>

                                            <!-- 完工时间 -->
                                            <TextBlock Grid.Column="2" 
                                                       Text="{Binding EndTime, StringFormat='yyyy-MM-dd HH:mm:ss'}" 
                                                       Padding="10,12" 
                                                       TextAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="12"/>
                                            <!-- 需求数量 -->
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding OrderQuantity}"
                                                       Padding="10,12"
                                                       TextAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="Gray"
                                                       FontSize="12"/>
                                            <!-- 状态 -->
                                            <TextBlock Grid.Column="4"
                                                       Text="{Binding OrderDetailsType,Converter={StaticResource EnumDescConverter}}"
                                                       Padding="10,12"
                                                       TextAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       >
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#F44336"/>
                                                        <Setter Property="FontWeight" Value="Normal"/>
                                                        <Setter Property="FontSize" Value="12"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding OrderDetailsType}" Value="ProcessingAnomaly">
                                                                <Setter Property="Foreground" Value="#FF9800"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding OrderDetailsType}" Value="NormalCompletion">
                                                                <Setter Property="Foreground" Value="#4CAF50"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </ScrollViewer>
            </Border>
        </Grid>
    </Border>

</UserControl>
