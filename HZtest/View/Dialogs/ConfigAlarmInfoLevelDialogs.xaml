<UserControl x:Class="HZtest.View.Dialogs.ConfigAlarmInfoLevelDialogs"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HZtest.View.Dialogs"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="700">

    <Border Background="White" BorderBrush="Gray" BorderThickness="2" CornerRadius="5" Padding="20" Width="700" Height="500">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- 关闭按钮（右上角） -->
            <Button Grid.Row="0" 
                    Grid.Column="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,-10,-10,0"
                    Content="✕"
                    Command="{Binding CloseCommand}"
                    Width="32" 
                    Height="32"
                    FontSize="16"
                    FontWeight="Bold"
                    Background="Transparent"
                    Foreground="#666666"
                    BorderThickness="0"
                    Cursor="Hand"
                    ToolTip="关闭">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF4444"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <!-- 第一行：查询区域 -->
            <Grid Grid.Row="0" Margin="0,10,0,10"  Grid.ColumnSpan="2"   >
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="230"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 报警代码标签 -->
                <TextBlock Grid.Column="0" Text="报警代码：" VerticalAlignment="Center" FontSize="20"/>

                <!-- 输入框 -->
                <TextBox Grid.Column="1" 
                         Text="{Binding SearchAlarmCode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Height="30" 
                         FontSize="20"
                         VerticalContentAlignment="Center"
                         Margin="5,0"/>

                <!-- 查询按钮 -->
                <Button Grid.Column="2" 
                        Content="查询" 
                        Command="{Binding SearchCommand}"
                        Width="60" 
                        Height="30"
                        Margin="10,0"
                        Cursor="Hand"/>
                <!-- 新增按钮（靠右） -->
                <Button Grid.Column="3" 
                    Grid.Row="0"
                        Content="+ 新增报警配置" 
                        Command="{Binding AddCommand}"
                        Width="120" 
                        Height="30"
                        Background="#2196F3"
                        Foreground="White"
                        Cursor="Hand"/>
            </Grid>


            <!-- 第二行：数据列表 -->
            <Border Grid.Row="2"
                    Grid.ColumnSpan="2"
                    BorderBrush="#DDDDDD" 
                    BorderThickness="1" 
                    CornerRadius="4">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- 表头 -->
                        <Grid Background="#F5F5F5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="报警代码" FontWeight="Bold" Padding="10,8" TextAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="报警级别" FontWeight="Bold" Padding="10,8" TextAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="修改时间" FontWeight="Bold" Padding="10,8" TextAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="操作" FontWeight="Bold" Padding="10,8" TextAlignment="Center"/>
                        </Grid>

                        <!-- 数据行 -->
                        <ItemsControl Grid.Row="1" ItemsSource="{Binding AlarmConfigList}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#EEEEEE" 
                                            BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="180"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- 报警代码 -->
                                            <TextBlock Grid.Column="0" 
                                                       Text="{Binding AlarmCode}" 
                                                       Padding="10,12" 
                                                       TextAlignment="Center"
                                                       VerticalAlignment="Center"/>

                                            <!-- 报警级别 -->
                                            <TextBlock Grid.Column="1" 
                                                       Text="{Binding AlarmLevel}" 
                                                       Padding="10,12" 
                                                       TextAlignment="Center"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding AlarmLevel}" Value="ErrorLevel">
                                                                <Setter Property="Foreground" Value="#F44336"/>
                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding AlarmLevel}" Value="MessageLevel">
                                                                <Setter Property="Foreground" Value="#FF9800"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding AlarmLevel}" Value="LOW">
                                                                <Setter Property="Foreground" Value="#4CAF50"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!-- 修改时间 -->
                                            <TextBlock Grid.Column="2" 
                                                       Text="{Binding ModifyTime, StringFormat='yyyy-MM-dd HH:mm:ss'}" 
                                                       Padding="10,12" 
                                                       TextAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="Gray"
                                                       FontSize="12"/>

                                            <!-- 操作按钮 -->
                                            <StackPanel Grid.Column="3" 
                                                        Orientation="Horizontal" 
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                <Button Content="修改" 
                                                        Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Width="50" 
                                                        Height="26"
                                                        Margin="5,0"
                                                        Background="#4CAF50"
                                                        Foreground="White"
                                                        Cursor="Hand"/>

                                                <Button Content="删除" 
                                                        Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        Width="50" 
                                                        Height="26"
                                                        Margin="5,0"
                                                        Background="#F44336"
                                                        Foreground="White"
                                                        Cursor="Hand"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </ScrollViewer>
            </Border>


        </Grid>
    </Border>

</UserControl>
