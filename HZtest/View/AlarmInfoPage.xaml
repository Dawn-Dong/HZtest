<!--//目前好用的版本如上-->

<Page x:Class="HZtest.View.AlarmInfoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:HZtest.View"
      xmlns:ctrl="clr-namespace:HZtest.Converters.View"  
      xmlns:control="clr-namespace:HZtest.Resources_资源.Control"  
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AlarmInfoPage">

    <Page.Resources>
        <ctrl:CountToVisibilityConverter x:Key="CountToVis"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 顶部标题 -->
        <TextBlock Text="报警信息页面" 
                   Grid.Row="0" Grid.Column="0" 
                   FontSize="24" FontWeight="Bold" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center"/>

        <Grid Grid.Row="0" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- 刷新按钮 -->
            <Button Content="刷新报警信息" 
                Grid.Column="0" 
                Width="150" Height="40" Margin="10" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center" 
                Command="{Binding RefreshAlarmInfoCommand}"/>
            <!-- 配置报警信息按钮 -->
            <Button Content="配置报警信息" 
                Grid.Column="1" 
                Width="150" Height="40" Margin="10" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center" 
                Command="{Binding ConfigAlarmInfoCommand}"/>

        </Grid>

        <!-- 数据展示区域 -->
        <Grid Grid.Row="1" Grid.ColumnSpan="2">
            <Grid.Background>
                <SolidColorBrush Color="#FF171717" />
            </Grid.Background>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- 表头行 -->
                <RowDefinition Height="*"/>
                <!-- 数据行 -->
            </Grid.RowDefinitions>
            <!-- 表头 -->
            <Grid Grid.Row="0" Background="#2D2D30" Height="36">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="报警代码" 
                           Grid.Column="0" 
                           Foreground="LightGray" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           FontSize="14"/>
                <TextBlock Text="报警类型" 
                           Grid.Column="1" 
                           Foreground="LightGray" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           FontSize="14"/>
                <TextBlock Text="报警级别" 
                           Grid.Column="2" 
                           Foreground="LightGray" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           FontSize="14"/>
                <TextBlock Text="报警时间" 
                            Grid.Column="3" 
                            Foreground="LightGray" 
                            FontWeight="Bold" 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center"
                            FontSize="14"/>
                <TextBlock Text="报警内容" 
                           Grid.Column="4" 
                           Foreground="LightGray" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           FontSize="14"/>

            </Grid>

            <!-- ✅ 修复5：添加 ItemTemplate (关键！) -->
            <ItemsControl ItemsSource="{Binding AlarmInfoList}"
                          Grid.Row="1"
                          Visibility="{Binding AlarmInfoList.Count, 
                                     Converter={StaticResource CountToVis}, 
                                     ConverterParameter='>0'}" 
                VirtualizingPanel.IsVirtualizing="True">
                <!-- 关键：开启纵向滚动 -->
                <ItemsControl.Template>
                    <ControlTemplate TargetType="ItemsControl">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" 
                          HorizontalScrollBarVisibility="Disabled"
                          CanContentScroll="True">
                            <ItemsPresenter/>
                        </ScrollViewer>
                    </ControlTemplate>
                </ItemsControl.Template>
                <ItemsControl.ItemTemplate>
                    <!--<DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            -->
                    <!--<TextBlock 
                                       Grid.Column="0"
                                       Text="{Binding AlarmCode}" 
                                       Margin="12,8" 
                                       Foreground="White"
                                       FontFamily="Consolas"
                                       TextTrimming="CharacterEllipsis"
                                       FontSize="13"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                            <TextBlock 
                                       Grid.Column="1"
                                       Text="{Binding AlarmType}" 
                                       Margin="12,8" 
                                       Foreground="White"
                                       FontFamily="Consolas"
                                       TextTrimming="CharacterEllipsis"
                                       FontSize="13"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>

                            <TextBlock 
                                       Grid.Column="2"
                                       Text="{Binding AlarmLevel}" 
                                       Margin="12,8" 
                                       Foreground="White"
                                       FontFamily="Consolas"
                                       TextTrimming="CharacterEllipsis"
                                       FontSize="13"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>

                            <TextBlock 
                                       Grid.Column="3"
                                       Text="{Binding AlarmTime}" 
                                       Margin="12,8" 
                                       Foreground="White"
                                       FontFamily="Consolas"
                                       TextTrimming="CharacterEllipsis"
                                       FontSize="13"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                            
                            <TextBlock Grid.Column="4" 
                                       Text="{Binding AlarmContent}" 
                                       Margin="12,8" 
                                       TextTrimming="CharacterEllipsis"
                                       FontSize="14"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>-->
                    <!--
                            
                            
                        </Grid>
                    </DataTemplate>-->

                    <DataTemplate>
                        <Grid>
                            <!-- 列定义 -->
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- ============================================ -->
                            <!-- 关键：行的背景色根据 AlarmLevel 变化 -->
                            <!-- ============================================ -->
                            <Grid.Style>
                                <Style TargetType="Grid">
                                    <!-- 默认背景：透明 -->
                                    <Setter Property="Background" Value="Transparent"/>

                                    <!-- 触发器：根据 AlarmLevel 的值改变背景 -->
                                    <Style.Triggers>

                                        <!-- ErrorLevel = 浅红色背景 -->
                                        <DataTrigger Binding="{Binding AlarmLevel}" Value="ErrorLevel">
                                            <Setter Property="Background" Value="#33FF6B6B"/>
                                        </DataTrigger>

                                        <!-- MessageLevel = 浅橙色背景 -->
                                        <DataTrigger Binding="{Binding AlarmLevel}" Value="MessageLevel">
                                            <Setter Property="Background" Value="#33FFA500"/>
                                        </DataTrigger>

                                        <!-- 可以扩展其他级别 -->
                                        <DataTrigger Binding="{Binding AlarmLevel}" Value="WarningLevel">
                                            <Setter Property="Background" Value="#33FFFF00"/>
                                        </DataTrigger>

                                    </Style.Triggers>
                                </Style>
                            </Grid.Style>

                            <!-- 第0列：报警代码 -->
                            <TextBlock Grid.Column="0"
                                       Text="{Binding AlarmCode}" 
                                       Margin="12,8" 
                                       Foreground="White"
                                       FontFamily="Consolas"
                                       TextTrimming="CharacterEllipsis"
                                       FontSize="13"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>

                            <!-- 第1列：报警类型 -->
                            <TextBlock Grid.Column="1"
                                       Text="{Binding AlarmType}" 
                                       Margin="12,8" 
                                       Foreground="White"
                                       FontFamily="Consolas"
                                       TextTrimming="CharacterEllipsis"
                                       FontSize="13"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>

                            <!-- ============================================ -->
                            <!-- 第2列：报警级别（文字也变色） -->
                            <!-- ============================================ -->
                            <TextBlock Grid.Column="2"
                                       Margin="12,8" 
                                       FontFamily="Consolas"
                                       FontSize="13"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center">  
    
                                <!-- 报警级别 -->
                                <Run Text="{Binding AlarmLevel}">
                                    <Run.Style>
                                        <Style TargetType="Run">
                                            <Setter Property="Foreground" Value="White"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding AlarmLevel}" Value="ErrorLevel">
                                                    <Setter Property="Foreground" Value="#FFFF4444"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding AlarmLevel}" Value="MessageLevel">
                                                    <Setter Property="Foreground" Value="#FFFFA500"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Run.Style>
                                </Run>
    
                                <!-- 自动/手动标记 -->
                                <Run>
                                    <Run.Style>
                                        <Style TargetType="Run">
                                            <Setter Property="FontSize" Value="10"/>
                                            <Style.Triggers>
                                                <!-- True = 自动（蓝色背景+白色字） -->
                                                <DataTrigger Binding="{Binding IsAutoPasing}" Value="True">
                                                    <Setter Property="Text" Value=" 自动 "/>
                                                    <Setter Property="Foreground" Value="Green"/>
                                                </DataTrigger>
                                                <!-- False = 手动（紫色背景+白色字） -->
                                                <DataTrigger Binding="{Binding IsAutoPasing}" Value="False">
                                                    <Setter Property="Text" Value=" 手动 "/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Run.Style>
                                </Run>
                            </TextBlock>


                            <!-- 第3列：报警时间 -->
                            <TextBlock Grid.Column="3"
                                   Text="{Binding AlarmTime}" 
                                   Margin="12,8" 
                                   Foreground="White"
                                   FontFamily="Consolas"
                                   TextTrimming="CharacterEllipsis"
                                   FontSize="13"
                                   HorizontalAlignment="Center" 
                                   VerticalAlignment="Center"/>

                            <!-- ============================================ -->
                            <!-- 第4列：报警内容（文字变色） -->
                            <!-- ============================================ -->
                            <TextBlock Grid.Column="4"
                               Text="{Binding AlarmContent}" 
                               Margin="12,8" 
                               TextTrimming="CharacterEllipsis"
                               FontSize="14"
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center">
                                <TextBlock.ToolTip>
                                    <ToolTip Content="{Binding AlarmContent}" MaxWidth="400"/>
                                </TextBlock.ToolTip>
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <!-- 默认：白色文字 -->
                                        <Setter Property="Foreground" Value="White"/>

                                        <Style.Triggers>
                                            <!-- ErrorLevel = 浅红色文字 -->
                                            <DataTrigger Binding="{Binding AlarmLevel}" Value="ErrorLevel">
                                                <Setter Property="Foreground" Value="#FFFF6B6B"/>
                                            </DataTrigger>

                                            <!-- MessageLevel = 橙色文字 -->
                                            <DataTrigger Binding="{Binding AlarmLevel}" Value="MessageLevel">
                                                <Setter Property="Foreground" Value="#FFFFA500"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 无数据提示 -->
            <TextBlock Grid.RowSpan="2" 
                       Text="当前无报警" 
                       Visibility="{Binding AlarmInfoList.Count, 
                                 Converter={StaticResource CountToVis}, 
                                 ConverterParameter='0'}" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"
                       FontSize="24" 
                       FontWeight="Bold"
                       Foreground="#FFD32F2F"/>

            <Grid Grid.Row="1" Grid.RowSpan="2" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.Background>
                    <SolidColorBrush Color="#80000000" Opacity="0.8"/>
                </Grid.Background>
                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                    <control:CircularProgressControl Width="48" Height="48"/>
                    <TextBlock Text="加载中..." 
                               Foreground="White" 
                               FontSize="16" 
                               Margin="0,12,0,0"
                               HorizontalAlignment="Center"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
    
    
    
    
    
   