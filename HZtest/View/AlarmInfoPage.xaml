<!--//目前好用的版本如上-->

<Page x:Class="HZtest.View.AlarmInfoPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:HZtest.View"
      xmlns:ctrl="clr-namespace:HZtest.Converters.View"  
      xmlns:control="clr-namespace:HZtest.Resources_资源.Control"  
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AlarmInfoPage">

    <Page.Resources>
        <ctrl:CountToVisibilityConverter x:Key="CountToVis"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 顶部标题 -->
        <TextBlock Text="报警信息页面" 
                   Grid.Row="0" Grid.Column="0" 
                   FontSize="24" FontWeight="Bold" 
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Center"/>

        <Grid Grid.Row="0" Grid.Column="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- 刷新按钮 -->
            <Button Content="刷新报警信息" 
                Grid.Column="0" 
                Width="150" Height="40" Margin="10" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center" 
                Command="{Binding RefreshAlarmInfoCommand}"/>
            <!-- 配置报警信息按钮 -->
            <Button Content="配置报警信息" 
                Grid.Column="1" 
                Width="150" Height="40" Margin="10" 
                HorizontalAlignment="Center" 
                VerticalAlignment="Center" 
                Command="{Binding ConfigAlarmInfoCommand}"/>

        </Grid>

        <!-- 数据展示区域 -->
        <Grid Grid.Row="1" Grid.ColumnSpan="2">
            <Grid.Background>
                <SolidColorBrush Color="#FF171717" />
            </Grid.Background>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- 表头行 -->
                <RowDefinition Height="*"/>
                <!-- 数据行 -->
            </Grid.RowDefinitions>
            <!-- 表头 -->
            <Grid Grid.Row="0" Background="#2D2D30" Height="36">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="报警代码" 
                           Grid.Column="0" 
                           Foreground="LightGray" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           FontSize="14"/>
                <TextBlock Text="报警类型" 
                           Grid.Column="1" 
                           Foreground="LightGray" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           FontSize="14"/>
                <TextBlock Text="报警级别" 
                           Grid.Column="2" 
                           Foreground="LightGray" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           FontSize="14"/>
                <TextBlock Text="报警时间" 
                            Grid.Column="3" 
                            Foreground="LightGray" 
                            FontWeight="Bold" 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center"
                            FontSize="14"/>
                <TextBlock Text="报警内容" 
                           Grid.Column="4" 
                           Foreground="LightGray" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           VerticalAlignment="Center"
                           FontSize="14"/>

            </Grid>

            <!-- ✅ 修复5：添加 ItemTemplate (关键！) -->
            <ItemsControl ItemsSource="{Binding AlarmInfoList}"
                          Grid.Row="1"
                          Visibility="{Binding AlarmInfoList.Count, 
                                     Converter={StaticResource CountToVis}, 
                                     ConverterParameter='>0'}" 
                VirtualizingPanel.IsVirtualizing="True">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock 
                                       Grid.Column="0"
                                       Text="{Binding AlarmCode}" 
                                       Margin="12,8" 
                                       Foreground="White"
                                       FontFamily="Consolas"
                                       TextTrimming="CharacterEllipsis"
                                       FontSize="13"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                            <TextBlock 
                                       Grid.Column="1"
                                       Text="{Binding AlarmType}" 
                                       Margin="12,8" 
                                       Foreground="White"
                                       FontFamily="Consolas"
                                       TextTrimming="CharacterEllipsis"
                                       FontSize="13"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>

                            <TextBlock 
                                       Grid.Column="2"
                                       Text="{Binding AlarmLevel}" 
                                       Margin="12,8" 
                                       Foreground="White"
                                       FontFamily="Consolas"
                                       TextTrimming="CharacterEllipsis"
                                       FontSize="13"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>

                            <TextBlock 
                                       Grid.Column="3"
                                       Text="{Binding AlarmTime}" 
                                       Margin="12,8" 
                                       Foreground="White"
                                       FontFamily="Consolas"
                                       TextTrimming="CharacterEllipsis"
                                       FontSize="13"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                            
                            <TextBlock Grid.Column="4" 
                                       Text="{Binding AlarmContent}" 
                                       Margin="12,8" 
                                       TextTrimming="CharacterEllipsis"
                                       FontSize="14"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 无数据提示 -->
            <TextBlock Grid.RowSpan="2" 
                       Text="当前无报警" 
                       Visibility="{Binding AlarmInfoList.Count, 
                                 Converter={StaticResource CountToVis}, 
                                 ConverterParameter='0'}" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center"
                       FontSize="24" 
                       FontWeight="Bold"
                       Foreground="#FFD32F2F"/>

            <Grid Grid.Row="1" Grid.RowSpan="2" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.Background>
                    <SolidColorBrush Color="#80000000" Opacity="0.8"/>
                </Grid.Background>
                <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                    <control:CircularProgressControl Width="48" Height="48"/>
                    <TextBlock Text="加载中..." 
                               Foreground="White" 
                               FontSize="16" 
                               Margin="0,12,0,0"
                               HorizontalAlignment="Center"/>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
    
    
    
    
    
   