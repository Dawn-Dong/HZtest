<Window x:Class="HZtest.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:HZtest"
        xmlns:helpers="clr-namespace:HZtest.AdditionalUIAttributes_附加UI属性.ViewHelper"
        mc:Ignorable="d"
        Title="华中数控" Height="600" Width="990"
        MinHeight="550"
        MinWidth="900"
        >
    <Grid Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="20"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <!-- 标签列 -->
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="LightGray" Grid.RowSpan="8" />
        <Button x:Name="HomeButton" Content="主页" Grid.Column="0" Grid.Row="0" Click="HomeButton_Click" Cursor="Hand"/>
        <Button x:Name="FileButton" Content="文件" Grid.Column="0" Grid.Row="1" Click="FileButton_Click" Cursor="Hand"/>
        <Button x:Name="AlarmInfoButton" Content="报警信息" Grid.Column="0" Grid.Row="2" Click="AlarmInfoButton_Click" Cursor="Hand"/>
        <Button x:Name="ToolInfoButton" Content="刀具信息" Grid.Column="0" Grid.Row="3" Click="ToolInfoButton_Click" Cursor="Hand"/>
        <Button x:Name="UserVariablesButton" Content="用户变量" Grid.Column="0" Grid.Row="4" Click="UserVariablesButton_Click" Cursor="Hand"/>
        <Button x:Name="RelativeCoordinateSystemButton" Content="相对坐标系" Grid.Column="0" Grid.Row="5" Click="RelativeCoordinateSystemButton_Click" Cursor="Hand"/>
        <Button x:Name="RegisterOperationButton" Content="寄存器操作" Grid.Column="0" Grid.Row="6" Click="RegisterOperationButton_Click" Cursor="Hand"/>
        <Button x:Name="OrderManagementButton" Content="订单管理" Grid.Column="0" Grid.Row="7" Click="OrderManagementButton_Click" Cursor="Hand"/>

        <Frame Grid.Column="1"  Grid.RowSpan="8" x:Name="MainFrame" NavigationUIVisibility="Hidden"/>

        <!--增加左右结构 右边做错误信息的跑马灯提示 左边依旧提示当前运行设备-->
        <Grid Grid.Column="0" Grid.Row="8" Grid.ColumnSpan="2">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="StatusTextBlock"  Grid.Column="0" FontSize="16" FontWeight="Bold"  />

            <!--<Border Grid.Column="1"  >
                <Canvas  ClipToBounds="True">
                    <TextBlock
                           Text="{Binding AlarmMessageText}" 
                           FontSize="14" 
                           FontWeight="Bold"
                           helpers:MainWindowMarqueeHelper.IsMarquee="{Binding IsMarqueeEnabled}"
                           helpers:MainWindowMarqueeHelper.Speed="70"
                        >

                        <TextBlock.Foreground>
                            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                <GradientStop Color="#FFD70027"/>
                                <GradientStop Color="#FF030303" Offset="1"/>
                                <GradientStop Color="#FF510311" Offset="1"/>
                            </LinearGradientBrush>
                        </TextBlock.Foreground>
                    </TextBlock>
                </Canvas>
            </Border>-->
            <Border Grid.Column="1">
                <Canvas ClipToBounds="True" x:Name="MarqueeCanvas">
                    <TextBlock x:Name="AlertTextBlock"
                   helpers:MainWindowMarqueeHelper.IsMarquee="{Binding IsMarqueeEnabled}"
                   helpers:MainWindowMarqueeHelper.Speed="50"
                   helpers:InlineBindingHelper.InlinesSource="{Binding AlertInlines}"
                   Canvas.Left="0"
                   Canvas.Top="0"           
                   CacheMode="BitmapCache"
                   RenderOptions.BitmapScalingMode="LowQuality"
                   TextOptions.TextFormattingMode="Display"
                   TextOptions.TextHintingMode="Animated"
                   UseLayoutRounding="True"
                   SnapsToDevicePixels="True">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontSize" Value="14"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Canvas>
            </Border>

        </Grid>




    </Grid>

</Window>
