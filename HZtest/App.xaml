<Application x:Class="HZtest.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:HZtest"
             xmlns:controls ="clr-namespace:HZtest.Converters.View"
             xmlns:universalControls ="clr-namespace:HZtest.Converters_值转换"
             >

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- 合并矢量图资源 -->
                <ResourceDictionary Source="/Resources-资源/Icons.xaml"/>
                <!-- 引入资源字典 -->
                <ResourceDictionary Source="Resources-资源/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <controls:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <universalControls:EnumToDescriptionConverter x:Key="EnumToDescriptionConverter"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
