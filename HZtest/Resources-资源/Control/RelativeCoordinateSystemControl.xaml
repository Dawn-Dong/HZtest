<UserControl x:Class="HZtest.Resources_资源.Control.RelativeCoordinateSystemControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:HZtest.Resources_资源.Control"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="150"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"  HorizontalAlignment="Left">
            <Button  
                Content="修改" 
                Command="{Binding ChangeXCommand}"
                Margin="5"
                Height="30"
                Width="60"
                Background="#4CAF50"
                Foreground="White"/>
            <TextBlock  Text="mm" Foreground="Blue"   Margin="10,0,0,0"  FontSize="30"   TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center"  />
        </StackPanel>

        <StackPanel Grid.Row="1" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"  HorizontalAlignment="Left">
            <Button  
                Content="修改" 
                Command="{Binding ChangeYCommand}"
                Margin="5"
                Height="30"
                Width="60"
                Background="#4CAF50"
                Foreground="White"/>
            <TextBlock  Text="mm" Foreground="Blue" FontSize="30"   Margin="10,0,0,0" TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center"  />
        </StackPanel>

        <StackPanel Grid.Row="2" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"  HorizontalAlignment="Left">
            <Button  
                Content="修改" 
                Command="{Binding ChangeZCommand}"
                Margin="5"
                Height="30"
                Width="60"
                Background="#4CAF50"
                Foreground="White"/>
            <TextBlock  Text="mm" Foreground="Blue" FontSize="30"   Margin="10,0,0,0" TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center"  />
        </StackPanel>
        <StackPanel Grid.Row="3" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"  HorizontalAlignment="Left">
            <Button  
                Content="修改" 
                Command="{Binding ChangeBCommand}"
                Margin="5"
                Height="30"
                Width="60"
                Background="#4CAF50"
                Foreground="White"/>
            <TextBlock  Text="deg" Foreground="Blue" FontSize="30"   Margin="10,0,0,0" TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center"  />
        </StackPanel>
        <StackPanel Grid.Row="4" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"  HorizontalAlignment="Left">
            <Button  
                Content="修改" 
                Command="{Binding ChangeCCommand}"
                Margin="5"
                Height="30"
                Width="60"
                Background="#4CAF50"
                Foreground="White"/>
            <TextBlock  Text="deg" Foreground="Blue" FontSize="30"   Margin="10,0,0,0" TextAlignment="Center" VerticalAlignment="Center" HorizontalAlignment="Center"  />
        </StackPanel>


        <!-- ✅ X轴 -->
        <TextBlock Grid.Row="0" Grid.Column="0" Foreground="Blue" FontSize="30" TextAlignment="Center" VerticalAlignment="Center">
            <Viewbox Width="24" Height="24">
                <Path Data="{StaticResource RotationAxis}" Fill="#4CAF50"/>
            </Viewbox>X
        </TextBlock>
        <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"  HorizontalAlignment="Left">
            <TextBlock  Text="{Binding XAxisCoordinateSystemValue}" Foreground="Blue" FontSize="30" TextAlignment="Center" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- ✅ Y轴 -->
        <TextBlock Grid.Row="1" Grid.Column="0" Foreground="Blue" FontSize="30" TextAlignment="Center" VerticalAlignment="Center">
            <Viewbox Width="24" Height="24">
                <Path Data="{StaticResource RotationAxis}" Fill="#4CAF50"/>
            </Viewbox>Y
        </TextBlock>
        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"  HorizontalAlignment="Left">
            <TextBlock  Text="{Binding YAxisCoordinateSystemValue}" Foreground="Blue" FontSize="30" TextAlignment="Center" VerticalAlignment="Center"/>

        </StackPanel>
        <!-- ✅ Z轴 -->
        <TextBlock Grid.Row="2" Grid.Column="0" Foreground="Blue" FontSize="30" TextAlignment="Center" VerticalAlignment="Center">
            <Viewbox Width="24" Height="24">
                <Path Data="{StaticResource RotationAxis}" Fill="#4CAF50"/>
            </Viewbox>Z
        </TextBlock>
        <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"  HorizontalAlignment="Left">
            <TextBlock  Text="{Binding ZAxisCoordinateSystemValue}" Foreground="Blue" FontSize="30" TextAlignment="Center" VerticalAlignment="Center"/>

        </StackPanel>
        <!-- ✅ B轴（关键修改） -->
        <TextBlock Grid.Row="3" Grid.Column="0" Foreground="Blue" FontSize="30" TextAlignment="Center" VerticalAlignment="Center">
            <Viewbox Width="24" Height="24">
                <Path Data="{StaticResource BCRotationAxis}" Fill="#4CAF50"/>
            </Viewbox>B
        </TextBlock>
        <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"  HorizontalAlignment="Left">
            <TextBlock  Text="{Binding BAxisCoordinateSystemValue}" Foreground="Blue" FontSize="30" TextAlignment="Center" VerticalAlignment="Center"/>

        </StackPanel>
        <!-- ✅ C轴 -->
        <TextBlock Grid.Row="4" Grid.Column="0" Foreground="Blue" FontSize="30" TextAlignment="Center" VerticalAlignment="Center">
            <Viewbox Width="24" Height="24">
                <Path Data="{StaticResource BCRotationAxis}" Fill="#4CAF50"/>
            </Viewbox>C
        </TextBlock>
        <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"  HorizontalAlignment="Left">
            <TextBlock  Text="{Binding CAxisCoordinateSystemValue}" Foreground="Blue" FontSize="30" TextAlignment="Center" VerticalAlignment="Center"/>

        </StackPanel>
    </Grid>


</UserControl>
